# Copy to mcp-server/.env

# Backend API the MCP tools call. Local dev: http://localhost:8000/api
# Production: your Render URL, e.g. https://foodexpress-api.onrender.com/api
FOODEXPRESS_API_URL=http://localhost:8000/api

# Optional: pre-set an auth token so tools work without calling `login` first.
# FOODEXPRESS_AUTH_TOKEN=

# --- LLM provider for the AI tools (recommend_dish / summarize / smart_order) ---
# MCP_LLM_PROVIDER = gemini | ollama | auto (default)
#   auto  -> uses Gemini when GEMINI_API_KEY is set, otherwise Ollama.
MCP_LLM_PROVIDER=auto

# Gemini (hosted API). Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ollama (local server). Only used when the provider resolves to ollama.
# Install from https://ollama.com, then: ollama pull qwen2.5
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5
