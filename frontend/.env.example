# Copy to frontend/.env for local dev.

# Backend API base URL. In local dev this points at your Django server.
# In production (Vercel) set this to your Render backend URL, e.g.
#   https://foodexpress-api.onrender.com/api
VITE_API_URL=http://localhost:8000/api

# Google Sign-In (optional). Get an OAuth 2.0 Web Client ID from
# https://console.cloud.google.com/apis/credentials and paste it here.
# Leave blank to hide the "Continue with Google" button.
VITE_GOOGLE_CLIENT_ID=

# Razorpay: the frontend does NOT need the key here — the backend returns the
# publishable key_id via /orders/{id}/create_payment/. Set keys on the backend.
