# Copy to backend/.env for local dev. Never commit the real .env.

# Core Django
SECRET_KEY=dev-insecure-key-change-me
DEBUG=True
ALLOWED_HOSTS=*
# DATABASE_URL=postgres://user:pass@host:5432/dbname   # defaults to sqlite
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI menu assistant.
# CHAT_PROVIDER: "auto" (default) uses Gemini if GEMINI_API_KEY is set, else Ollama.
#   Force one with "gemini" or "ollama".
CHAT_PROVIDER=auto
LLM_TIMEOUT=30
CHAT_THROTTLE_RATE=20/min

# Gemini (hosted) — use this in production (Render/Vercel can't reach a local Ollama).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ollama (local dev) — point at your local Ollama server.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5

# --- Payments: Razorpay ---
# Leave BOTH blank to run in simulated test mode (orders can still be "paid" via
# the /simulate_payment/ endpoint — used by the MCP server and local demos).
# For real test-mode checkout, paste your TEST keys from
# https://dashboard.razorpay.com/app/keys  (they start with rzp_test_).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Keep True for demos/tests so /simulate_payment/ is allowed. Set False in prod
# if you want to force real signature-verified payments only.
PAYMENTS_TEST_MODE=True

# --- Google Sign-In ---
# OAuth 2.0 Web Client ID from https://console.cloud.google.com/apis/credentials
# Must match VITE_GOOGLE_CLIENT_ID in the frontends. Blank = Google login off.
GOOGLE_CLIENT_ID=
