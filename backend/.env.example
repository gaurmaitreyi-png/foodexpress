# Copy to backend/.env for local dev. Never commit the real .env.

# Core Django
SECRET_KEY=dev-insecure-key-change-me
DEBUG=True
ALLOWED_HOSTS=*
# DATABASE_URL=postgres://user:pass@host:5432/dbname   # defaults to sqlite
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI menu assistant (Ollama). Point at your local Ollama server.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5
OLLAMA_TIMEOUT=30
CHAT_THROTTLE_RATE=20/min
